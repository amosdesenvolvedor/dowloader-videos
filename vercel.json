{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/*.py": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/download",
      "dest": "/api/download.py"
    },
    {
      "src": "/api/downloads",
      "dest": "/api/downloads.py"
    },
    {
      "src": "/styles.css",
      "dest": "/styles.css"
    },
    {
      "src": "/app.js",
      "dest": "/app.js"
    },
    {
      "src": "/favicon.svg",
      "dest": "/favicon.svg"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/manifest.webmanifest",
      "dest": "/manifest.webmanifest"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/icon-192.png",
      "dest": "/icon-192.png"
    },
    {
      "src": "/icon-512.png",
      "dest": "/icon-512.png"
    },
    {
      "src": "/apple-touch-icon.png",
      "dest": "/apple-touch-icon.png"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
